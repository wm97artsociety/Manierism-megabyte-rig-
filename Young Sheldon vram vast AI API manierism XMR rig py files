        vast_usd_total: Number(w.vast_usd_total || 0)
      });
    } catch (e) {}
  }
  entries.sort((a, b) => b.crude_oil_mb - a.crude_oil_mb);
  res.json({ market: "crude_oil", count: entries.length, wallets: entries });
});

