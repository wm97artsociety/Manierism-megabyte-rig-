def list_young_sheldon_nfts(blockchain_wallet_address: str):
    if not web3.is_connected():
        print("❌ No blockchain connection.")
        return []
    contract = web3.eth.contract(address=NFT_CONTRACT_ADDRESS, abi=NFT_ABI)
    try:
        balance = contract.functions.balanceOf(blockchain_wallet_address).call()
    except Exception as e:
        print(f"❌ Error calling balanceOf: {e}")
        return []

    nfts = []
    for i in range(balance):
        try:
            token_id = contract.functions.tokenOfOwnerByIndex(blockchain_wallet_address, i).call()
            uri = contract.functions.tokenURI(token_id).call()
            meta = fetch_nft_metadata(uri)
            nfts.append({"token_id": token_id, "uri": uri, "meta": meta})
        except Exception as e:
            print(f"❌ Error reading token {i}: {e}")
            continue
    return nfts

