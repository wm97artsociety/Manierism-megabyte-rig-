5.3. Function to list NFTs + fetch metadata

`python
def fetchnftmetadata(uri: str):
    try:
        resp = requests.get(uri, timeout=10)
        resp.raiseforstatus()
        return resp.json()
    except Exception as e:
        print(f"❌ Failed to fetch metadata: {e}")
        return None

def listrignfts(wallet_address: str):
    contract = web3.eth.contract(address=NFTCONTRACT, abi=NFTABI)
    try:
        balance = contract.functions.balanceOf(wallet_address).call()
    except Exception as e:
        print(f"❌ Error calling balanceOf: {e}")
        return []

    nfts = []
    for i in range(balance):
        try:
            tokenid = contract.functions.tokenOfOwnerByIndex(walletaddress, i).call()
            uri = contract.functions.tokenURI(token_id).call()
            meta = fetchnftmetadata(uri)
            nfts.append({"tokenid": tokenid, "uri": uri, "meta": meta})
        except Exception as e:
            print(f"❌ Error reading token {i}: {e}")
            continue
    return nfts
`

