        else:
            target[resource_name] = target.get(resource_name, Decimal("0")) + amt

        save_wallet(wallet)
        save_wallet(target)
        print(f"✅ Sent {format_large_number(amt)} {'EGP' if resource_name == 'egp_value' else resource_name.replace('_',' ')} from {wallet['wallet_id']} to {target_id}")

