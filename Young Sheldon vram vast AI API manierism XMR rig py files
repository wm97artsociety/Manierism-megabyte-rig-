// server.js - Read-only API for ManierismMegabytes (VRAM + Vast + Crude Oil)
// Run with: node server.js
const express = require("express");
const fs = require("fs");
const path = require("path");
const Decimal = require("decimal.js");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

const USER_DOWNLOADS = path.join(require("os").homedir(), "Downloads");
const BASEDIR = path.join(USER_DOWNLOADS, "manierismmegabytes");
const TARGETDIR = path.join(BASEDIR, "rigs");

const EGP_RATE = new Decimal("30.90");
const MB_USD_RATE = new Decimal("5.00");
const CACHE_USD_RATE = new Decimal("0.42");
const KWH_USD_RATE = new Decimal("0.17");
const BANDWIDTH_USD_RATE = new Decimal("0.42");
const TORRENT_USD_RATE = MB_USD_RATE;
const VRAM_TO_MB_RATE = new Decimal("250");

const MB_EGP_RATE = MB_USD_RATE.times(EGP_RATE);
const CACHE_EGP_RATE = CACHE_USD_RATE.times(EGP_RATE);
const KWH_EGP_RATE = KWH_USD_RATE.times(EGP_RATE);
const BANDWIDTH_EGP_RATE = BANDWIDTH_USD_RATE.times(EGP_RATE);
const TORRENT_EGP_RATE = TORRENT_USD_RATE.times(EGP_RATE);
const VRAM_EGP_RATE = VRAM_TO_MB_RATE.times(MB_EGP_RATE);

function loadWallet(walletId) {
  const filePath = path.join(TARGETDIR, `${walletId}_wallet.json`);
  if (!fs.existsSync(filePath)) return null;
  const raw = fs.readFileSync(filePath, "utf8");
  return JSON.parse(raw);
}

function calculateTotalEGP(w) {
  const capsule = new Decimal(String(w.capsule_value_mb || 0));
  const cache = new Decimal(String(w.cache_value_mb || 0));
  const kwh = new Decimal(String(w.real_kwh || 0));
  const bandwidth = new Decimal(String(w.bandwidth_MBps || 0));
  const torrent = new Decimal(String(w.torrent_value_mb || 0));
  const vram = new Decimal(String(w.vram_gb || 0));
  return capsule.times(MB_EGP_RATE)
    .plus(cache.times(CACHE_EGP_RATE))
    .plus(kwh.times(KWH_EGP_RATE))
    .plus(bandwidth.times(BANDWIDTH_EGP_RATE))
    .plus(torrent.times(TORRENT_EGP_RATE))
    .plus(vram.times(VRAM_EGP_RATE));
}

app.get("/", (req, res) => res.json({ status: "ok", message: "ManierismMegabytes Monetization API live" }));

